{
  "name": "testsquad-hometask",
  "version": "1.0.0",
  "description": "GitHub Automation Tests with WDIO",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "wdio": "wdio run src/config/wdio.conf.js",
    "generate-allure": "npx allure generate ./allure-results -o ./allure-report --clean",
    "open-allure": "npx allure open ./allure-report",
    "wdio-allure": "npm run wdio && npm run generate-allure && npm run open-allure",
    "coverage": "c8 npm run wdio",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "prettier": "prettier --check src/",
    "prettier:fix": "prettier --write src/",
    "format": "npm run prettier:fix && npm run lint:fix",
    "prepush": "npm run format && npm run lint && npm run prettier && npm run wdio"
  },
  "keywords": [
    "webdriverio",
    "automation",
    "testing",
    "github"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@faker-js/faker": "^10.4.0",
    "@wdio/allure-reporter": "^9.20.0",
    "@wdio/cli": "^9.20.0",
    "@wdio/local-runner": "^9.20.0",
    "@wdio/mocha-framework": "^9.20.0",
    "@wdio/spec-reporter": "^9.20.0",
    "allure-commandline": "^2.34.1",
    "c8": "^10.1.3",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "globals": "^16.5.0",
    "prettier": "^3.6.2",
    "webdriverio": "^9.20.0"
  }
}
